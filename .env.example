# Copie este arquivo para .env e preencha os valores

PORT=3000
NODE_ENV=development

# Neon PostgreSQL — use a DATABASE_URL completa OU as variáveis individuais PG*
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# PGHOST=...
# PGDATABASE=...
# PGUSER=...
# PGPASSWORD=...
# PGSSLMODE=require

# JWT secret
JWT_SECRET=troque-por-uma-string-aleatoria-longa

# Chave para criar usuários via API POST /api/admin/users
ADMIN_KEY=troque-por-uma-chave-segura

# Usuários seed criados automaticamente (apenas NODE_ENV != production)
# Formato JSON array — defina no .env local, nunca commite senhas reais
SEED_USERS=[{"login":"seu.login","name":"Seu Nome","password":"SuaSenha@123"}]

# Integração GLPI — Automações / Atendimento
GLPI_API_URL=https://suporte.cardway.net.br/apirest.php
GLPI_APP_TOKEN=seu-app-token-glpi-aqui
GLPI_USER_TOKEN=seu-user-token-glpi-aqui
